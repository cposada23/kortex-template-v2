# Kortex template — example environment file
# Copy to .env (gitignored) and fill with real values.

# Anthropic API (optional — only if running custom Claude integration)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API (optional)
OPENAI_API_KEY=sk-your-key-here

# OpenRouter (gateway to Perplexity Sonar, Gemini, etc.)
OPENROUTER_API_KEY=sk-or-your-key-here

# Firecrawl (optional — only if ingesting external URLs)
FIRECRAWL_API_KEY=fc-your-key-here
